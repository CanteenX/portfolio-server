NODE_ENV=development
PORT=7002
MONGO_URI=mongodb://127.0.0.1:27017/admin_panel
JWT_SECRET_SUPER_ADMIN=change_me_super_admin_secret
JWT_SECRET_ADMIN=change_me_admin_secret
JWT_EXPIRES_IN=1d
CLIENT_CODE=default-client
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
TRUST_PROXY=0
ENABLE_SEED=true
SUPER_ADMIN_SEED_PASSWORD=SuperAdmin@123
ADMIN_SEED_PASSWORD=Admin@123
API_KEY_HASH_SALT=replace_api_key_hash_salt
ENABLE_API_DOCS=true

# Payment (optional)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=

# File storage
STORAGE_BACKEND=local
FILE_UPLOAD_DIR=uploads
FILE_UPLOAD_MAX_BYTES=52428800

# S3 (optional, when STORAGE_BACKEND=s3)
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# SMTP (optional)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
