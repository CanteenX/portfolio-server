/**
 * WhatsApp Bulk Messaging Handlers
 *
 * Handlers for bulk messaging operations - the core of WhatsApp message sending.
 * Manages audience targeting, message queueing, progress tracking, and analytics.
 *
 * Key Responsibilities:
 * - Create and manage bulk messaging configurations
 * - Build user audiences from filters
 * - Enqueue messages to RabbitMQ for worker processing
 * - Track message delivery stats in real-time
 * - Handle retry logic for failed messages
 * - Provide analytics and reporting
 *
 * Database Collections:
 * - BM-BulkMessagings: Bulk messaging configurations
 * - BM-MessageQueue: Individual messages awaiting processing
 * - BM-Campaigns: Parent campaigns
 * - BM-WhatsAppTemplates: Message templates
 * - BM-AudienceTypes: Reusable audience segments
 *
 * External Dependencies:
 * - RabbitMQ: Message queue for async processing
 * - Meta Graph API: Direct sending for test messages
 *
 * TODO: CHANGE THIS - Update user model references for audience building
 * TODO: CHANGE THIS - Update buildAudienceQuery() to match your user schema
 */

import { ERROR_CODES } from "@admin-platform/shared-types";
import type { Request, Response, NextFunction } from "express";
import mongoose from "mongoose";
import { z } from "zod";
import type { AuthenticatedRequest } from "../../core/auth/auth.types";
import { AppError } from "../../core/errors/app-error";
import { env } from "../../config/env";
import { logger } from "../../core/logging/logger";
import {
  BulkMessagingModel,
  MessageQueueModel,
  CampaignModel,
  WhatsAppTemplateModel,
  AudienceTypeModel,
} from "./models";

// ═══════════════════════════════════════════════════════════
// VALIDATION SCHEMAS
// ═══════════════════════════════════════════════════════════

const createBulkMessagingSchema = z.object({
  name: z.string().min(1).max(200).trim(),
  templateId: z.string().regex(/^[0-9a-fA-F]{24}$/),
  audienceFilter: z.record(z.any()).optional(),
  variableOverrides: z.array(z.object({
    position: z.number().int().min(1),
    customValue: z.string().optional(),
    fieldPath: z.string().optional(),
  })).optional(),
  scheduledFor: z.coerce.date().optional().nullable(),
});

const updateBulkMessagingSchema = z.object({
  name: z.string().min(1).max(200).trim().optional(),
  templateId: z.string().regex(/^[0-9a-fA-F]{24}$/).optional(),
  audienceFilter: z.record(z.any()).optional(),
  variableOverrides: z.array(z.object({
    position: z.number().int().min(1),
    customValue: z.string().optional(),
    fieldPath: z.string().optional(),
  })).optional(),
  scheduledFor: z.coerce.date().optional().nullable(),
});

const listBulkMessagingsSchema = z.object({
  skip: z.coerce.number().int().min(0).default(0),
  per_page: z.coerce.number().int().min(1).max(100).default(10),
  sorton: z.string().optional(),
  sortdir: z.enum(["asc", "desc"]).optional(),
  match: z.string().max(200).optional(),
  status: z.enum(["draft", "queued", "processing", "paused", "completed", "failed"]).optional(),
});

const getFailedMessagesSchema = z.object({
  skip: z.coerce.number().int().min(0).default(0),
  per_page: z.coerce.number().int().min(1).max(100).default(20),
  errorCategory: z.enum(["permanent", "policy", "rate_limit", "transient"]).optional(),
  match: z.string().max(50).optional(),
});

const previewAudienceSchema = z.object({
  audienceFilter: z.record(z.any()),
});

const testSendSchema = z.object({
  templateId: z.string().regex(/^[0-9a-fA-F]{24}$/),
  variableOverrides: z.array(z.object({
    position: z.number().int().min(1),
    customValue: z.string(),
  })).optional(),
  testPhoneNumbers: z.array(z.string().min(10).max(15)).min(1).max(5),
});

const analyticsQuerySchema = z.object({
  campaignId: z.string().regex(/^[0-9a-fA-F]{24}$/).optional(),
  startDate: z.coerce.date().optional(),
  endDate: z.coerce.date().optional(),
});

// ═══════════════════════════════════════════════════════════
// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════

function ensureValidObjectId(id: string): void {
  if (!mongoose.Types.ObjectId.isValid(id)) {
    throw new AppError(400, ERROR_CODES.BAD_REQUEST, "Invalid ID format");
  }
}

/**
 * Normalize phone number to 91XXXXXXXXXX format (India)
 * TODO: CHANGE THIS - Update for other country codes if needed
 */
function normalizePhone(phone: string): string {
  let cleaned = phone.replace(/[\s\-\(\)\+]/g, "");
  if (cleaned.startsWith("0")) cleaned = cleaned.slice(1);
  if (cleaned.length === 10) cleaned = "91" + cleaned;
  if (cleaned.startsWith("91") && cleaned.length === 12) return cleaned;
  return cleaned;
}

