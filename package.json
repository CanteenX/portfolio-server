{
  "name": "admin-panel-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "build:vercel": "node scripts/build-vercel.mjs",
    "start": "tsx src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint placeholder'",
    "test": "tsx --test src/__tests__/module-routes.test.ts src/__tests__/security.test.ts src/__tests__/validation.test.ts",
    "test:unit": "tsx --test src/__tests__/module-routes.test.ts src/__tests__/security.test.ts src/__tests__/validation.test.ts",
    "test:integration": "tsx --test src/__tests__/integration.test.ts",
    "validate:openapi": "node scripts/validate-openapi.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@aws-sdk/s3-request-presigner": "^3.1029.0",
    "@vercel/blob": "^2.3.3",
    "bcryptjs": "^2.4.3",
    "buffer-crc32": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3",
    "stripe": "^22.0.1",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pino": "^7.0.5",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "esbuild": "^0.28.0",
    "mongodb-memory-server": "^11.0.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
